import tkinter as tk


class TodoView(tk.Frame):
    def __init__(self, root):
        super().__init__(root)
        self.root = root
        self.root.title("Lista de Tareas")
        self.root.geometry("400x400")
        self.configure(padx=20, pady=20)
        self.pack()

        self._crear_boton()

    def _crear_boton(self):
        tk.Label(self, text="Nueva Tarea:", font=('Arial', 10)).pack(anchor="w")
        
        self.entry_tarea = tk.Entry(self, width=35)
        self.entry_tarea.pack(pady=5)

        self.btn_agregar = tk.Button(self, text="Agregar")
        self.btn_agregar.pack(pady=5)

        self.listbox = tk.Listbox(self, width=45, height=10)
        self.listbox.pack(pady=10)

        self.btn_completar = tk.Button(self, text="Marcar Completada")
        self.btn_completar.pack(side="left", padx=20)

        self.btn_eliminar = tk.Button(self, text="Eliminar")
        self.btn_eliminar.pack(side="right", padx=20)

    def obtener_entrada(self):
        return self.entry_tarea.get().strip()

    def limpiar_entrada(self):
        self.entry_tarea.delete(0, tk.END)

    def obtener_seleccion(self):
        seleccion = self.listbox.curselection()
        if seleccion:

            return self.listbox.get(seleccion)[4:]
        return None
    

    def limpiar_listbox(self):
        self.listbox.delete(0, tk.END)

    def insertar_en_listbox(self, texto_tarea):
        self.listbox.insert(tk.END, texto_tarea)
